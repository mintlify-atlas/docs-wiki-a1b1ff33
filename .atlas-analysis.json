    "IBlobContainer / BlobProviderBase (framework/src/Volo.Abp.BlobStoring/)",
    "IBackgroundJobManager / BackgroundJobWorker (framework/src/Volo.Abp.BackgroundJobs/)",
    "ISettingProvider / SettingDefinitionProvider (framework/src/Volo.Abp.Settings/)",
    "IFeatureChecker / FeatureDefinitionProvider (framework/src/Volo.Abp.Features/)",
    "AbpAspNetCoreMvcModule / AbpServiceConvention (framework/src/Volo.Abp.AspNetCore.Mvc/)",
